    {
      "name": "3. Изменение имени питомца",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let jsonData = pm.response.json();\r",
              "let oldName = pm.collectionVariables.get(\"name\");\r",
              "\r",
              "pm.test(\"New name is different from old name\", function () {\r",
              "    pm.expect(jsonData.name).to.not.eql(oldName);\r",
              "});\r",
              "\r",
              "pm.collectionVariables.set(\"name\", jsonData.name);\r",
              "\r",
              "pm.test(\"New name saved\", function () {\r",
              "    pm.expect(pm.collectionVariables.get(\"name\")).to.eql(jsonData.name);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
