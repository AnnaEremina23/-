    {
      "name": "4. Получение списка своих питомцев",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "let jsonData = pm.response.json();\r",
              "let savedName = pm.collectionVariables.get(\"name\");\r",
              "\r",
              "pm.test(\"Pets list is not empty\", function () {\r",
              "    pm.expect(jsonData.pets.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Saved name equals first pet name\", function () {\r",
              "    pm.expect(savedName).to.eql(jsonData.pets[0].name);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
